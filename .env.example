# Copy this file to .env and fill in real values from your Supabase project
# (Project Settings > API). Never commit .env — it's already in .gitignore.

# ---------------------------------------------------------------------------
# Client-exposed (safe to ship to the browser).
# Vite only inlines variables prefixed VITE_ into the client bundle, so this
# prefix is what makes a variable public — never put a secret behind it.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Server-only. No VITE_ prefix, so Vite never bundles these into client code.
# Used by src/lib/supabase/server.ts (per-request, respects RLS).
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Server-only, HIGH PRIVILEGE. Bypasses Row Level Security entirely.
# Used only by src/lib/supabase/admin.ts. Never expose this to the browser,
# never prefix it with VITE_, never log it.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---------------------------------------------------------------------------
# Reserved for future steps — not required yet, listed here so the shape of
# the config is visible up front.
# ---------------------------------------------------------------------------

# Xendit secret keys (server-only, never prefix with VITE_). Two keys scoped
# by permission: WRITE creates payments/invoices, READ checks their status.
# From the Xendit Dashboard > Settings > API Keys — use test/development keys
# until the real payment integration goes live.
XENDIT_SECRET_KEY_WRITE=
XENDIT_SECRET_KEY_READ=

# Xendit Dashboard > Settings > Webhooks > Verification Token. Compared
# against the x-callback-token header on every inbound webhook so a forged
# request can't fake a "payment confirmed" event.
XENDIT_WEBHOOK_VERIFICATION_TOKEN=

# Resend (resend.com) — sends the post-purchase review-request email. From
# your Resend dashboard's API Keys page. RESEND_FROM_EMAIL must be an address
# on a domain you've verified with Resend (e.g. reviews@yourdomain.com).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Where the "new order" notification email goes when a storefront order is
# placed. Optional — if unset, that notification is silently skipped (a
# missing address shouldn't ever block checkout).
STORE_OWNER_EMAIL=

# Public base URL of the storefront (no trailing slash), e.g.
# https://spadesph.com. Used to build the review-request link — the cron job
# has no incoming request to derive an origin from, unlike a normal page load.
SITE_URL=

# Shared secret the two Vercel-scheduled cron routes (review-requests,
# sync-channels-daily) check for in the `Authorization: Bearer <value>`
# header before running. Vercel automatically sends this exact env var as
# that header for crons defined in vercel.json, so don't rename it and don't
# reuse it for externally-triggered crons (see CRON_JOB_ORG_SECRET below) —
# rotating it only affects Vercel's own cron calls. Generate a long random
# string (e.g. `openssl rand -hex 32`). Without this set, the endpoints
# reject every request rather than running unauthenticated.
CRON_SECRET=

# Separate shared secret for cron routes triggered by an external scheduler
# instead of vercel.json (currently sync-channels-pull-orders, called by
# cron-job.org every 5 minutes). Kept independent from CRON_SECRET so
# rotating one never breaks the other — you must manually update the
# Authorization header value configured in cron-job.org's dashboard whenever
# you change this. Generate a long random string (e.g. `openssl rand -hex
# 32`).
CRON_JOB_ORG_SECRET=

# TikTok Shop Partner Center app credentials (see
# src/server/integrations/marketplaces/tiktok-shop). Per-shop OAuth tokens
# themselves go in the `marketplace_connections` table, not here — these two
# are just the app-level key/secret used to sign every API request and
# complete the OAuth token exchange. NOTE: marketplace_connections currently
# stores tokens as plain text (see that table's original migration comment
# about encrypting them at rest, which hasn't been implemented) — treat this
# table as sensitive.
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=

# Shopee Open Platform app credentials (see
# src/server/integrations/marketplaces/shopee). SHOPEE_ENV is "sandbox" or
# "live" — controls which base URL the adapter signs requests against.
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_ENV=sandbox

# Meta (Facebook) Pixel ID, from Meta Events Manager > Data Sources > your
# pixel ("Dataset ID" on that page). Client-exposed (VITE_ prefix) since the
# Pixel ID is not a secret — it's meant to be visible in the page source.
VITE_FB_PIXEL_ID=

# Lazada credentials — added once that adapter is built (see the stub file
# in src/server/integrations/marketplaces/lazada).
# LAZADA_APP_KEY=
# LAZADA_APP_SECRET=

# ShipMate / ProfitMate service-to-service API keys — added when those
# integrations are built.
# SHIPMATE_API_KEY=
# PROFITMATE_API_KEY=
